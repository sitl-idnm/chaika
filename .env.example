# Copy to .env.local and fill in. Public vars live in .env (committed).

# --- Lead delivery: Telegram (POST /api/lead) ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=-1001234567890

# --- Lead delivery: Email via SMTP (POST /api/lead) ---
# SMTP mailbox that sends the notifications (e.g. Timeweb: smtp.timeweb.ru).
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
# true for port 465 (SSL); false for 587 (STARTTLS). Optional — inferred from port.
SMTP_SECURE=true
SMTP_USER=send@example.com
SMTP_PASS=your_mailbox_password
# From address (defaults to SMTP_USER). Comma-separated recipients in LEAD_EMAIL_TO.
LEAD_EMAIL_FROM=Чайка <send@example.com>
LEAD_EMAIL_TO=manager1@example.com,manager2@example.com

# --- Yandex SmartCaptcha (protects the lead forms) ---
# Client key (ysc1_...) — public, embedded in the widget.
NEXT_PUBLIC_SMARTCAPTCHA_SITE_KEY=ysc1_your_client_key
# Server key (ysc2_...) — secret, used for server-side validation.
SMARTCAPTCHA_SERVER_KEY=ysc2_your_server_key

# --- VK Ads leads -> Google Sheets ---
# OAuth access token for the VK Ads (ads.vk.ru) cabinet. Obtained manually (10-min window).
VK_ADS_ACCESS_TOKEN=
# Shared secret guarding POST /api/vk/webhook (passed as ?secret= or X-Webhook-Secret header).
VK_WEBHOOK_SECRET=
# Google Apps Script Web App that appends rows to the spreadsheet (no GCP / no billing).
# Deploy the script (see docs), paste its /exec URL and the secret you set inside it.
SHEETS_WEBAPP_URL=https://script.google.com/macros/s/XXXX/exec
SHEETS_WEBAPP_SECRET=
# Protects the Vercel cron endpoint GET /api/vk/sync (Vercel sends it as a Bearer token).
CRON_SECRET=

# --- Yandex.Metrika counter id (already set in committed .env) ---
NEXT_PUBLIC_YM_ID=110512444
